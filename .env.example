# GoHighLevel Authentication
# Choose ONE of the following methods:

# Method 1: API Token (Private Integration / Personal Access Token)
# Generate in GHL: Settings > Business Profile > API Key
GHL_API_TOKEN=

# Method 2: OAuth 2.0 (recommended for app integrations)
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=
GHL_REFRESH_TOKEN=
# Optionally pre-fill access token (auto-refreshed if refresh token is set)
GHL_ACCESS_TOKEN=

# GoHighLevel Configuration
GHL_LOCATION_ID=your_location_id_here
GHL_API_BASE=https://services.leadconnectorhq.com
GHL_API_VERSION=2021-07-28

# Optional: OAuth callback URL for token exchange helper
# GHL_OAUTH_CODE=
# GHL_OAUTH_REDIRECT_URI=https://your-app.example.com/oauth/callback
